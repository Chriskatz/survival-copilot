# Copy to .env and tweak. Loaded by bot.py via python-dotenv.

# Meshtastic node BLE name or MAC. Leave blank to auto-pick first Meshtastic peripheral.
# Find via: meshtastic --ble-scan  (after `pip install meshtastic`)
MESH_BLE_ADDRESS=

# QVAC OpenAI-compatible HTTP endpoint (started via: qvac serve openai)
QVAC_BASE_URL=http://127.0.0.1:11434/v1
# Aliases defined in ./qvac.config.json (project root) under serve.models
QVAC_MODEL=co-pilot
QVAC_EMBED_MODEL=embed-mlm

# Only respond to messages starting with this prefix. Empty = respond to all texts.
# Keep a prefix on shared mesh — your AI shouldn't drown out human chatter.
TRIGGER_PREFIX=?

# Where to send replies: "dm" (direct to sender) or "channel" (same channel inbound came on)
REPLY_MODE=dm

# Per-segment delay (seconds) so LoRa duty-cycle doesn't get hammered
SEND_INTERVAL_S=2.0

# Hard cap on reply length BEFORE chunking, to keep on-air time sane
MAX_REPLY_CHARS=1000

# Base station location (decimal degrees, + alt in metres). The Wio usually has
# no GPS fix indoors, so set these to enable distance/bearing to senders in the
# log. Leave blank to disable (or set a fixed position on the node instead).
BASE_LAT=
BASE_LON=
BASE_ALT=
