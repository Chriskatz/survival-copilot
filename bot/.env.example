# Copy to .env and tweak. Loaded by bot.py via python-dotenv.

# Transport. Set MESH_SERIAL_PORT to use USB serial (recommended for a stationary
# base station — avoids the macOS BLE silent-drop that stalls inbound packets).
#   "auto" = auto-detect the USB port; or give a path like /dev/cu.usbmodem101.
# Leave blank to use BLE instead.
MESH_SERIAL_PORT=

# BLE only (ignored when MESH_SERIAL_PORT is set): node BLE name or MAC. Leave
# blank to scan and pick a device interactively at startup (auto-connects if one).
MESH_BLE_ADDRESS=

# QVAC OpenAI-compatible HTTP endpoint (started via: qvac serve openai)
QVAC_BASE_URL=http://127.0.0.1:11434/v1
# Aliases defined in ./qvac.config.json (project root) under serve.models
QVAC_MODEL=co-pilot
QVAC_EMBED_MODEL=embed-mlm

# Only respond to messages starting with this prefix. Empty = respond to all texts.
# Keep a prefix on shared mesh — your AI shouldn't drown out human chatter.
TRIGGER_PREFIX=?

# Where to send replies: "dm" (direct to sender) or "channel" (same channel inbound came on)
REPLY_MODE=dm

# Per-segment delay (seconds) so LoRa duty-cycle doesn't get hammered
SEND_INTERVAL_S=2.0

# Hard cap on reply length BEFORE chunking, to keep on-air time sane
MAX_REPLY_CHARS=1000

# Search-and-rescue log: one JSON line per inbound text message with the
# sender's last-known telemetry (GPS, power, RF link). Default lives under
# evidence/ (gitignored — it contains user locations). Set to "" to disable.
RESCUE_LOG_PATH=

# Base station location (decimal degrees, + alt in metres). The Wio usually has
# no GPS fix indoors, so set these to enable distance/bearing to senders in the
# log. Leave blank to disable (or set a fixed position on the node instead).
BASE_LAT=
BASE_LON=
BASE_ALT=

# ── Phase II: SDR broadcast ───────────────────────────────────────────────────
# Transmit HIGH/CRITICAL incident reports as FM audio via HackRF.
# ⚠  POC / demo only. Requires regulatory authorisation to transmit.
#    Set SDR_BROADCAST_ENABLED=true only in a controlled test environment.
SDR_BROADCAST_ENABLED=false
SDR_FREQUENCY_HZ=469660000      # 469.660 MHz
SDR_TX_GAIN=20                  # hackrf_transfer -x, VGA gain 0-47 dB
SDR_TX_AMP=0                    # hackrf_transfer -a, TX amp: 0=off 1=on
